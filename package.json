{
  "devDependencies": {
    "eslint": "^10.1.0",
    "eslint-config-google": "^0.14.0",
    "globals": "^17.4.0",
    "gulp": "^5.0.0",
    "gulp-rename": "^2.0.0",
    "gulp-zip": "^5.1.0",
    "jasmine-browser-runner": "^2.5.0",
    "json5": "^2.2.2",
    "webdriver-installer": "^1.3.2"
  },
  "dependencies": {
    "trace-anything": "^1.0.2"
  },
  "scripts": {
    "build": "npm ci && gulp",
    "install-drivers": "mkdir -p drivers && npx webdriver-installer drivers",
    "test": "npm run install-drivers && PATH=$PATH:drivers jasmine-browser-runner runSpecs",
    "serve": "npm run install-drivers && PATH=$PATH:drivers jasmine-browser-runner serve",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "version": "3.4.3"
}
